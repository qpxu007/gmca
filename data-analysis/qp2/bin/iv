#!/bin/bash

# Source the standardized environment configuration
SCRIPT_DIR=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
source "$SCRIPT_DIR/qp2_env.sh"

# Optional live-mode group check.
# Set QP2_LIVE_GROUPS to a colon-separated list of Unix groups that are
# allowed to use live mode. If unset, live mode is unrestricted (default
# for a standalone installation).
if [ -n "$QP2_LIVE_GROUPS" ] && [[ "$*" == *"--live"* ]]; then
    USER_GROUPS=$(id -nG "$USER")
    AUTHORIZED=false
    IFS=':' read -ra ALLOWED <<< "$QP2_LIVE_GROUPS"
    for group in $USER_GROUPS; do
        for allowed in "${ALLOWED[@]}"; do
            if [[ "$group" == "$allowed" ]]; then
                AUTHORIZED=true
                break 2
            fi
        done
    done
    if [ "$AUTHORIZED" = false ]; then
        echo "Live mode restricted: user '$USER' is not in QP2_LIVE_GROUPS ($QP2_LIVE_GROUPS)." >&2
        # Strip --live from arguments so the viewer opens in offline mode
        set -- "${@/--live/}"
    fi
fi

# Execute the Python script
$MYPYTHON -Xfrozen_modules=off -m qp2.image_viewer.ui.main "$@"