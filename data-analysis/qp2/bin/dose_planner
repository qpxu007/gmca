#!/bin/bash

# Source the standardized environment configuration
SCRIPT_DIR=$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")
source "$SCRIPT_DIR/qp2_env.sh"

# Load CCP4 module as required by this application
eval "${QP2_SETUP_CCP4:-. /etc/profile.d/modules.sh; module load ccp4}"

# Execute the Python script
$MYPYTHON -m qp2.radiation_decay.dose_planner "$@"