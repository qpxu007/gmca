        "peak_finding_min_distance": 7,
        "peak_finding_min_intensity": 10,
        "peak_finding_median_filter_size": null,
        "peak_finding_zscore_cutoff": 3.0
    },
    "xds": {
        "nproc": 32,
        "njobs": 4,
        "anomalous": true
    },
    "nxds": {
        "nproc": 16,
        "njobs": 4,
        "auto_merge": false
    },
    "xia2": {
        "pipeline": "xia2_dials",
        "nproc": 32,
        "njobs": 1,
        "fast": false,
        "trust_beam_centre": true
    },
    "xia2_ssx": {
        "nproc": 16,
        "njobs": 2
    },
    "autoproc": {
        "nproc": 16,
        "njobs": 4,
        "fast": true
    },
    "crystfel": {
        "nproc": 32,
        "peak_method": "peakfinder8",
        "min_snr": 4.5,
        "min_snr_biggest_pix": 3.5,
        "min_snr_peak_pix": 2.0,
        "min_sig": 6.0,
        "local_bg_radius": 3,
        "pdb_file": null,
