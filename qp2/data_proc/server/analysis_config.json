        "no_non_hits": true,
        "indexing_methods": "xgandalf",
        "xgandalf_fast": true,
        "no_refine": false,
        "no_check_peaks": false,
        "peakfinder8_fast": true,
        "asdf_fast": true,
        "no_retry": true,
        "no_multi": true,
        "push_res": 0.0,
        "integration_mode": "Standard",
        "extra_options": "",
