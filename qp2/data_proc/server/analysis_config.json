        "batch_size": 5,
        "beamstop_size": 100,
        "spot_size": 3,
        "spot_level": 6,
        "dist_cutoff": 20.0,
        "res_cutoff_low": 20.0,
        "res_cutoff_high": 2.5,
        "check_ice_rings": "T",
        "exclude_resolution_ranges": [],
        "min_spot_range_low": 15.0,
        "min_spot_range_high": 4.0,
        "min_spot_count": 2
