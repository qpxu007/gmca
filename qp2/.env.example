# QP2 Environment Configuration
# Copy this file to .env and fill in values for your deployment.
# Generate a secret key with: python -c "import secrets; print(secrets.token_hex(32))"

# --- Authentication (required) ---
QP2_JWT_SECRET_KEY=change-me-generate-with-python-secrets-token-hex-32

# --- Dev login bypass (optional, never use in production) ---
# QP2_TEST_USER=devuser
# QP2_TEST_PASS=devpassword

# --- LDAP (optional, facility-specific) ---
# QP2_LDAP_SERVER=ldap.example.org
# QP2_LDAP_USER_DN_TEMPLATE=uid={username},ou=people,dc=example,dc=org

# --- Kerberos (optional, facility-specific) ---
# QP2_KRB5_REALM=example.org

# --- PostgreSQL ---
QP2_PG_HOST=localhost
QP2_PG_PORT=5432
QP2_PG_USER=qp2user
QP2_PG_PASS=
QP2_PG_DB=user_data

# --- MySQL ---
MYSQL_HOST_BL1=localhost
MYSQL_HOST_BL2=localhost
MYSQL_GMCA_ACCOUNTS=localhost
MYSQL_USER=qp2user
MYSQL_PASS=

# --- Redis ---
REDIS_HOST_BL1=127.0.0.1
REDIS_HOST_BL2=127.0.0.1
REDIS_HOST_ANALYSIS_RESULTS=127.0.0.1

# --- Services ---
# DATAPROC_SERVER_URL=http://localhost:8025
# AI_SERVER_URL=http://localhost:8888/v1
# PBS_RPC_URL=http://localhost:8001/rpc

# --- Mode ---
# QP2_ENV=test   # set to "test" to force localhost for all services
